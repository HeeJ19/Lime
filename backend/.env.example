# Copy to .env and fill in real values for local development. Never commit .env.
#
# Production (Hugging Face Space secrets) needs only the first three:
GEMINI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
#
# Local dev / smoke tests only (not used by the FastAPI service itself):
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
